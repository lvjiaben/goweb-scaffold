      componentProps: {
        placeholder: "请输入文章摘要，用于列表简介",
        rows: 4,
      },
      fieldName: "summary",
      formItemClass: 'col-span-2 md:col-span-1',
      label: "文章摘要",
      rules: z.string().min(1, "文章摘要不能为空"),
    },
    {
      component: "Select",
      componentProps: {
        allowClear: true,
        class: 'w-full',
        options: statusOptions,
        placeholder: "请选择状态",
      },
