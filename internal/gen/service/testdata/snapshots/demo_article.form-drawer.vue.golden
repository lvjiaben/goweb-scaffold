<script lang="ts" setup>
import type { VbenFormSchema } from '#/adapter/form';
import type { DemoArticleApi } from '#/api/demo_article';

import { computed, nextTick, ref } from 'vue';

import { useVbenDrawer } from '@vben/common-ui';

import { breakpointsTailwind, useBreakpoints } from '@vueuse/core';

import { useVbenForm, z } from '#/adapter/form';
import { saveDemoArticle } from '#/api/demo_article';
import { getDemoArticleStatusOptions } from '../data';

const emit = defineEmits<{
  success: [];
}>();

const formData = ref<DemoArticleApi.DemoArticle>();
const statusOptions = getDemoArticleStatusOptions();

const schema: VbenFormSchema[] = [
    {
      component: "Input",
      componentProps: {
        placeholder: "请输入文章标题",
      },
      fieldName: "title",
      formItemClass: 'col-span-2 md:col-span-1',
